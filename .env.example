# ==============================================================================
# MathModelingAgents — 环境变量配置
# ==============================================================================
#
# 这个文件控制整个多 Agent 数学建模框架的运行参数。
# 每个设置下面都有注释说明它是干什么的、可以填什么值。
#
# 怎么用：
#   1. 把这个文件改名为 .env（如果还没改的话）
#   2. 按需要修改下面的值
#   3. 保存后重新运行 python main.py 即可生效
#
# 注意：.env 包含你的 API Key，已被 .gitignore 保护，不会被传到 Git。
#       如果你想分享配置给别人看，请复制 .env.example 并删掉敏感值。
#
# ==============================================================================


# ──────────────────────────────────────────────────────────────────────────────
# 1. LLM 提供商 — 你的 AI 模型从哪个通道调用
# ──────────────────────────────────────────────────────────────────────────────

# 大语言模型提供商，决定所有 Agent 通过哪个通道请求 AI 模型。
# 可填: opencode（OpenCode Go 中转）或 deepseek（DeepSeek 官方直连）
# 当前使用: OpenCode Go（你通过 Hermes 配置的中转服务）
MATHMODELING_LLM_PROVIDER=opencode

# 自定义后端地址。一般情况下留空即可，会自动使用默认地址。
# 留空时: opencode → https://opencode.ai/zen/go/v1
#          deepseek → https://api.deepseek.com/v1
# 如果你想指向自己的代理服务器，把地址填在这里。
MATHMODELING_BACKEND_URL=


# ──────────────────────────────────────────────────────────────────────────────
# 2. 降级链 — 主通道挂了自动切备用通道
# ──────────────────────────────────────────────────────────────────────────────

# 当"LLM 提供商"不可用时（比如 OpenCode Go 挂了、限流了），
# 框架会自动切换到这里的备用通道继续干活。
# 可填: deepseek（DeepSeek 官方 API）或 opencode
# 当前: 主用 OpenCode Go，挂了就切 DeepSeek 官方 API
MATHMODELING_FALLBACK_PROVIDER=deepseek

# 备用通道的自定义地址，一般留空用默认的 https://api.deepseek.com/v1
MATHMODELING_FALLBACK_BASE_URL=


# ──────────────────────────────────────────────────────────────────────────────
# 3. API 密钥（⚠️ 敏感信息，不能泄露给别人）
# ──────────────────────────────────────────────────────────────────────────────

# OpenCode Go 的 API 密钥 — 主通道（日常使用）
# 格式: sk- 开头的一串字符。
# 从你的 OpenCode 账户后台获取。
OPENCODE_GO_API_KEY=your_opencode_api_key_here

# DeepSeek 官方 API 的密钥 — 备用通道（主通道挂了自动切换）
# 格式: sk- 开头的一串字符。
# 去 platform.deepseek.com 注册账号就能拿到。
DEEPSEEK_API_KEY=your_deepseek_api_key_here


# ──────────────────────────────────────────────────────────────────────────────
# 4. 模型选择 — 用哪个 AI 大脑来做事
# ──────────────────────────────────────────────────────────────────────────────

# DeepSeek 提供两种模型:
#   deepseek-v4-pro   = 深度推理型，擅长复杂数学、逻辑、裁决（慢但聪明）
#   deepseek-v4-flash = 快速响应型，适合轻量任务（快但推理能力较弱）
#
# 下面的设置只在 LLM_PROVIDER=deepseek 时使用。
# OpenCode 模式下的模型分配代码里有更精细的按层配置，
# 想覆盖的话可以用 MATHMODELING_LAYER_MODEL_OVERRIDES 这条（见下）。

# "深思"模型的名称 — 给需要深度推理的角色用（Manager、建模师、Coder）
MATHMODELING_DEEP_THINK_LLM=deepseek-v4-pro

# "快想"模型的名称 — 给轻量任务用（数据分析、可视化、论文大纲等）
MATHMODELING_QUICK_THINK_LLM=deepseek-v4-flash

# 精细覆盖：如果你想单独改某一层某个角色的模型，在这里写 JSON。
# 格式: {"层名":{"角色":"模型名"}}
# 例子: 把论文层的写手换成别的模型:
#   MATHMODELING_LAYER_MODEL_OVERRIDES={"paper":{"writer":"qwen3.7-max"}}
# 可以改多层的多个角色，不改的保持默认。
# 默认情况下（不设）用到下面的分配:
#
#   Layer 1 问题分析: agent→v4-flash, manager→v4-pro
#   Layer 2 数学建模: agent→v4-pro,  manager→v4-pro  (全部pro, 数学推理重)
#   Layer 3 代码实现: algorithm→v4-flash, coder→v4-pro, visualizer→v4-flash, manager→v4-pro
#   Layer 4 论文写作: architect→v4-flash, writer→qwen3.7-max, visualizer→v4-flash, manager→v4-pro
#   Layer 5 敏感性:   agent→v4-flash, manager→v4-pro
#
# MATHMODELING_LAYER_MODEL_OVERRIDES={"paper":{"writer":"qwen3.7-max"}}


# ──────────────────────────────────────────────────────────────────────────────
# 5. 超时时间 — 每个阶段最多等多久
# ──────────────────────────────────────────────────────────────────────────────

# 框架共 5 层（问题分析 → 数学建模 → 代码实现 → 论文写作 → 敏感性分析）。
# 每一层的超时时间，单位是秒。
# 10800 秒 = 3 小时。深度推理模型（deepseek-v4-pro）有时要跑很久，
# 所以设得比较宽松。如果你的模型很快，可以改小。
#
# 改小有什么好处: 早点发现卡住了，早点重试。
# 改大会怎样:  如果模型真的卡死了，要多等 3 小时才能发现。

MATHMODELING_LAYER_TIMEOUT_PROBLEM=10800         # 第1层: 分析题目
MATHMODELING_LAYER_TIMEOUT_MODELING=10800        # 第2层: 数学建模+辩论
MATHMODELING_LAYER_TIMEOUT_IMPLEMENTATION=10800  # 第3层: 写代码+调试
MATHMODELING_LAYER_TIMEOUT_PAPER=10800           # 第4层: 写论文
MATHMODELING_LAYER_TIMEOUT_SENSITIVITY=10800     # 第5层: 敏感性分析


# ──────────────────────────────────────────────────────────────────────────────
# 6. 模型输出控制 — 控制 AI 回答的长度
# ──────────────────────────────────────────────────────────────────────────────

# 单次调用 AI 最多允许输出的 token 数（约等于字数）。
# 16384 是比较大的值，适合数学建模论文这种长输出场景。
# token 大致对应: 中文约 1.5 字/token，英文约 0.75 词/token。
# 如果你经常遇到回答被截断，把这个数调大。
MATHMODELING_DEFAULT_MAX_TOKENS=16384


# ──────────────────────────────────────────────────────────────────────────────
# 7. 辩论与重试 — Agent 之间的讨论和纠错机制
# ──────────────────────────────────────────────────────────────────────────────

# 第2层数学建模中，三位建模师（A、B、C）的最大辩论轮数。
# 每轮辩论三个建模师各发言一次，Manager 判断是否需要继续。
# 设 10 意味着最多 10 轮 × 3 个人 = 30 次 LLM 调用。
# 调小: 省钱省时间，但可能讨论不充分。
# 调大: 讨论更充分，但可能争论不休。
MATHMODELING_MAX_DEBATE_ROUNDS=10

# 第3层代码实现中，如果代码出错或质量不达标，最多重试几次。
# 每次重试 AlgorithmDesigner → Coder → Visualizer 全链条重跑。
# 3 次是合理值：给够纠错机会但不会无限卡死。
MATHMODELING_MAX_IMPL_RETRIES=3


# ──────────────────────────────────────────────────────────────────────────────
# 8. 层开关 — 控制哪些阶段要跑
# ──────────────────────────────────────────────────────────────────────────────

# 是否跑第5层（敏感性分析）。默认关，因为不是所有题目都需要。
# true = 跑, false = 跳过
MATHMODELING_ENABLE_SENSITIVITY=false

# 要执行的层，数字用逗号隔开。
# 1 = 问题分析, 2 = 数学建模, 3 = 代码实现, 4 = 论文写作, 5 = 敏感性分析
#
# 默认 1,2,3,4 表示跑前四层（去掉第5层敏感性）。
# 调试技巧: 比如你只想重跑论文，可以设成 4 就会跳过前面的3层。
MATHMODELING_SELECTED_LAYERS=1,2,3,4


# ──────────────────────────────────────────────────────────────────────────────
# 9. 输出控制 — 生成的论文和中间文件放哪里
# ──────────────────────────────────────────────────────────────────────────────

# 最终输出目录。留空 = 自动在桌面创建一个以题目命名的文件夹。
# 如果你想把输出固定到某个地方，这里填路径，比如:
#   Windows: C:\Users\joeji\Desktop\math_results
#   WSL:     /home/joeji/math_results
MATHMODELING_OUTPUT_DIR=

# 输出文件格式。当前固定为 obsidian_md（Obsidian 兼容的 Markdown）。
MATHMODELING_OUTPUT_FORMAT=obsidian_md

# 数据缓存目录，存中间计算结果。默认项目根目录下的 cache 文件夹。
MATHMODELING_DATA_CACHE_DIR=./cache

# 运行结果目录，存每次运行的汇总文件。默认项目根目录下的 results 文件夹。
MATHMODELING_RESULTS_DIR=./results


# ──────────────────────────────────────────────────────────────────────────────
# 10. 代码沙盒 — Agent 写的代码怎么安全执行
# ──────────────────────────────────────────────────────────────────────────────

# Agent 写的 Python 代码实际上会执行。下面是沙盒安全限制。

# 单个代码块最多允许运行多少秒。超时就杀掉进程。
# 30 秒对大多数数学建模计算（矩阵运算、优化、绘图）足够了。
MATHMODELING_CODE_TIMEOUT=30

# 单个代码块最多用多少 MB 内存。
# 512 MB 足够处理中等规模数据。如果跑大数据集可能不够。
MATHMODELING_CODE_MAX_MEMORY_MB=512

# 是否强制所有计算必须由代码实际执行。
# true = Agent 不能凭空编数字，必须真的跑代码算出结果来。
# false = Agent 可以凭经验估算（不推荐，会导致结果不可靠）。
MATHMODELING_ENFORCE_CODE_COMPUTATION=true
